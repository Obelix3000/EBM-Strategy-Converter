# ============================================================
# .gitignore – EBM Strategy Converter
# Nur zwingend notwendige Quelldateien sind im Repository.
# ============================================================

# --- Python-Laufzeitdateien ---
__pycache__/
*.py[cod]
*$py.class
*.pyo

# --- Virtuelle Environments ---
.venv/
venv/
env/
ENV/

# --- Betriebssystem ---
.DS_Store
Thumbs.db
desktop.ini

# --- IDEs und Editoren ---
.vscode/
.idea/
*.swp
*.swo

# --- KI-Agenten-Konfiguration (intern) ---
.claude/
CLAUDE.md

# --- B99-Maschinendaten und ZIP-Archive ---
# (Baujob-Dateien sind proprietäre Maschinendaten, nicht im Repo)
*.B99
*.b99
*.zip

# --- Externe Binärdateien und dekompilierte Artefakte ---
ABSPathOptimizer.exe
ABSPathOptimizer.exe_extracted/
pyinstxtractor.py
decompiled.py
disasm.txt

# --- Urheberrechtlich geschützte Literatur ---
*.pdf

# --- Temporäre Arbeitsdateien / Scratchdateien ---
_temp_pdf.txt
extract_pdf.py
perf_test.py

# --- App-Ausgaben ---
EBM_Output/
data/

# --- Interne Notizen und Planungsdokumente ---
bug_behebung.md
literature_sources.md
update.md
implemetierungsplan.md
src/test.md

# --- Streamlit-Cache ---
.streamlit/
